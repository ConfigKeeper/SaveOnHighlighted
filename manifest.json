{
  "manifest_version": 3,
  "name": "Save On Highlighted",
  "description": "Save selected words with a keyboard shortcut for later Anki import.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "downloads",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "save-selection": {
      "suggested_key": {
        "default": "Ctrl+S"
      },
      "description": "Save currently selected text"
    }
  },
  "action": {
    "default_title": "Save On Highlighted",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
